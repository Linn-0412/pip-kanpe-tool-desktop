  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the main desktop window.",
  "windows": ["main", "pip"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
