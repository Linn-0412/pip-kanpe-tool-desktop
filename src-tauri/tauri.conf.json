{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PiP Kanpe Tool",
  "version": "0.1.0",
  "identifier": "com.linn0412.pip-kanpe-tool-desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PiP カンペツール Desktop",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "TAURI_UPDATER_PUBLIC_KEY_PLACEHOLDER",
      "endpoints": [
        "https://github.com/Linn-0412/pip-kanpe-tool-desktop/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

